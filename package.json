{
  "name": "noat",
  "displayName": "NOAT",
  "description": "Notion-style notes inside your IDE. Local-first, git-versioned, MCP-accessible.",
  "version": "0.1.0",
  "publisher": "maxpintchouk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxpintchouk/noat"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "noat",
          "title": "NOAT",
          "icon": "media/noat.svg"
        }
      ]
    },
    "views": {
      "noat": [
        {
          "id": "noatNotes",
          "name": "Notes",
          "icon": "media/noat.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "noat.noteEditor",
        "displayName": "NOAT Note",
        "selector": [
          {
            "filenamePattern": "*.noat.json"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "noat.newNote",
        "title": "NOAT: New Note",
        "icon": "$(new-file)"
      },
      {
        "command": "noat.newFolder",
        "title": "NOAT: New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "noat.refresh",
        "title": "NOAT: Refresh Notes",
        "icon": "$(refresh)"
      },
      {
        "command": "noat.rename",
        "title": "Rename"
      },
      {
        "command": "noat.delete",
        "title": "Delete"
      },
      {
        "command": "noat.moveToGlobal",
        "title": "Move to Global"
      },
      {
        "command": "noat.moveToRepo",
        "title": "Move to This Repo"
      },
      {
        "command": "noat.openNotesRepo",
        "title": "NOAT: Open Notes Store in Terminal"
      },
      {
        "command": "noat.searchNotes",
        "title": "NOAT: Search Notes",
        "icon": "$(search)"
      },
      {
        "command": "noat.openNote",
        "title": "NOAT: Open Note"
      }
    ],
    "keybindings": [
      {
        "command": "noat.searchNotes",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "noat.searchNotes",
        "key": "ctrl+p",
        "mac": "cmd+p",
        "when": "focusedView == noatNotes"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "noat.newNote",
          "when": "view == noatNotes",
          "group": "navigation@1"
        },
        {
          "command": "noat.newFolder",
          "when": "view == noatNotes",
          "group": "navigation@2"
        },
        {
          "command": "noat.refresh",
          "when": "view == noatNotes",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "noat.newNote",
          "when": "view == noatNotes && viewItem =~ /scope|folder/",
          "group": "1_create@1"
        },
        {
          "command": "noat.newFolder",
          "when": "view == noatNotes && viewItem =~ /scope|folder/",
          "group": "1_create@2"
        },
        {
          "command": "noat.rename",
          "when": "view == noatNotes && viewItem =~ /note|folder/",
          "group": "2_modify@1"
        },
        {
          "command": "noat.delete",
          "when": "view == noatNotes && viewItem =~ /note|folder/",
          "group": "2_modify@2"
        },
        {
          "command": "noat.moveToGlobal",
          "when": "view == noatNotes && viewItem == note-repo",
          "group": "3_move@1"
        },
        {
          "command": "noat.moveToRepo",
          "when": "view == noatNotes && viewItem == note-global",
          "group": "3_move@1"
        }
      ],
      "commandPalette": [
        {
          "command": "noat.openNote",
          "when": "false"
        },
        {
          "command": "noat.rename",
          "when": "false"
        },
        {
          "command": "noat.delete",
          "when": "false"
        },
        {
          "command": "noat.moveToGlobal",
          "when": "false"
        },
        {
          "command": "noat.moveToRepo",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.webview.json --noEmit && tsc -p tsconfig.mcp.json --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "seed": "node scripts/seed-mock-notes.mjs",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@blocknote/code-block": "^0.48.1",
    "@blocknote/core": "^0.48.1",
    "@blocknote/mantine": "^0.48.1",
    "@blocknote/react": "^0.48.1",
    "@blocknote/server-util": "^0.48.1",
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/langs-precompiled": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@shikijs/types": "^4.3.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
